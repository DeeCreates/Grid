{
  "compilerOptions": {
    // ============================================
    // LANGUAGE & ENVIRONMENT
    // ============================================
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,

    // ============================================
    // STRICTNESS (Enhanced for production)
    // ============================================
    "strict": true,
    "noUnusedLocals": true,        // ✅ Changed to true (catch unused vars)
    "noUnusedParameters": true,    // ✅ Changed to true (catch unused params)
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "exactOptionalPropertyTypes": false,
    
    // ============================================
    // MODULE RESOLUTION & PATHS
    // ============================================
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@features/*": ["./src/features/*"],
      "@utils/*": ["./src/lib/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@stores/*": ["./src/stores/*"],
      "@types/*": ["./src/types/*"],
      "@services/*": ["./src/services/*"],
      "@assets/*": ["./src/assets/*"],
      "@styles/*": ["./src/styles/*"],
      "@config/*": ["./src/config/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@validations/*": ["./src/validations/*"],
      "@constants/*": ["./src/constants/*"],
      "@helpers/*": ["./src/helpers/*"]
    },

    // ============================================
    // INTEROPERABILITY
    // ============================================
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // ============================================
    // DECORATORS (Optional - for future use)
    // ============================================
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // ============================================
    // OUTPUT & SOURCE MAPS
    // ============================================
    "sourceMap": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "declaration": false,
    "declarationMap": false,

    // ============================================
    // ADVANCED
    // ============================================
    "preserveSymlinks": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",

    // ============================================
    // TYPE DEFINITIONS
    // ============================================
    "types": [
      "vite/client",
      "node",
      "@types/react",
      "@types/react-dom",
      "@types/web-push"
    ]
  },

  // ============================================
  // INCLUDE/EXCLUDE
  // ============================================
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "src/**/*.json",
    "vite.config.ts",
    "tailwind.config.js",
    "postcss.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**",
    "**/__mocks__/**"
  ],

  // ============================================
  // PROJECT REFERENCES
  // ============================================
  "references": [{ "path": "./tsconfig.node.json" }],

  // ============================================
  // TS-NODE (for script execution)
  // ============================================
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "esModuleInterop": true
    },
    "transpileOnly": true,
    "files": true
  }
}